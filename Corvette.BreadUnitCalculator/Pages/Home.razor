@page "/"

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-secondary text-white">
            <h3 class="mb-0">Калькулятор ХЕ</h3>
        </div>
        
        <div class="card-body">
            <div class="row g-3 mb-4">
                <div class="col-6">
                    <label class="form-label fw-bold">Инсулин</label>
                    <input type="number"
                           step="0.5"
                           min="0.5"
                           class="form-control form-control-lg" 
                           inputmode="decimal"
                           @bind="_insulin"
                           @bind:event="oninput"
                           @bind:after="UpdateTable" />
                </div>
    
                <div class="col-6">
                    <label class="form-label fw-bold">ХЕ</label>
                    <input type="number" 
                           step="0.1"
                           min="0.1"
                           class="form-control form-control-lg" 
                           inputmode="decimal"
                           @bind="_breadUnits"
                           @bind:event="oninput" 
                           @bind:after="UpdateTable" />
                </div>
            </div>

            @if (Coefficient > 0)
            {
                <div class="alert alert-secondary text-center">
                    <strong>Коэффициент: </strong> @Coefficient?.ToString("F2") ХЕ за 1 ед. инсулина
                </div>
            }

            <!-- Таблица результатов -->
            @if (_tableData.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover mt-3">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center" style="width: 50%">Инсулин</th>
                                <th class="text-center" style="width: 50%">ХE</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _tableData)
                            {
                                <tr class="@(row.Insulin == _insulin ? "table-secondary fw-bold" : "")">
                                    <td class="text-center">@row.Insulin.ToString("F1")</td>
                                    <td class="text-center">@row.BreadUnits.ToString("F1")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private double? _insulin;    
    private double? _breadUnits;      
    private double? Coefficient => _breadUnits > 0 ? _insulin / _breadUnits : null;

    // Данные для таблицы
    private List<TableRow> _tableData = [];

    protected override void OnInitialized()
    {
        UpdateTable();
    }

    private void UpdateTable()
    {
        var insulin = _insulin.GetValueOrDefault();
        var breadUnits = _breadUnits.GetValueOrDefault();
        var coefficient = Coefficient.GetValueOrDefault();
        
        // Проверяем, что оба значения введены и положительные
        if (insulin <= 0 || breadUnits <= 0)
            return;
        
        var step = 0.5;
        var min = 0.5;

        var table = new List<TableRow>
        {
            new TableRow { Insulin = insulin },
        };
        
        for (var i = 1; i <= 3; i++)
        {
            var down = insulin - i * step;
            var up = insulin + i * step;
            
            if (down >= min)
                table.Add(new TableRow{Insulin = down});
            
            table.Add(new TableRow{Insulin = up});
        }
        
        foreach (var row in table)
        {
            row.BreadUnits = Math.Round(row.Insulin / coefficient, 1);
        }
    
        _tableData = table.OrderBy(x => x.Insulin).ToList();
    }

    // Класс для строки таблицы
    private class TableRow
    {
        public double Insulin { get; set; }
        public double BreadUnits { get; set; }
    }
}